    { id: 43, title: "Cookie Clicker",         thumbnail: "https://yoplay.io/cache/data/image/game/cookie-clicker1-m160x96.jpg", embed: `<iframe src="https://ozgames.io/cookie-clicker.embed" width="1280" height="720" frameborder="0" border="0" scrolling="none"></iframe>`},
    { id: 44, title: "Dude Theft Auto",        thumbnail: "https://ozgames.io/cache/data/image/game/Dude-Theft-Auto-1-m240x144.JPG", embed: `<iframe src="https://ozgames.io/dude-theft-auto.embed" width="1280" height="720" frameborder="0" border="0" scrolling="none"></iframe>`},
    { id: 45, title: "Five Nights At Freddy's(FNAF)", thumbnail: "https://ozgames.io/cache/data/image/game/Five-Nights-at-Freddy---s-m240x144.jpg", embed: `<iframe src="https://ozgames.io/five-nights-at-freddys.embed" width="1280" height="720" frameborder="0" border="0" scrolling="none"></iframe>`},
    { id: 46, title: "Ragdoll Hit Stickman",   thumbnail: "https://ozgames.io/cache/data/image/game/ragdoll-hit-stickman-cover-m240x144.png", embed: `<iframe src="https://ozgames.io/ragdoll-hit-stickman.embed" width="1280" height="720" frameborder="0" border="0" scrolling="none"></iframe>`},
    { id: 47, title: "Murder",                 thumbnail: "https://ozgames.io/cache/data/image/game/murder-m240x144.JPG", embed: `<iframe src="https://ozgames.io/murder.embed" width="1280" height="720" frameborder="0" border="0" scrolling="none"></iframe>`},
    { id: 48, title: "Time Shooter",           thumbnail: "https://imgs.crazygames.com/time-shooter-2_16x9/20241113040556/time-shooter-2_16x9-cover?metadata=none&quality=100&width=1200&height=630&fit=crop", embed: `<iframe src="https://ozgames.io/time-shooter.embed" width="1280" height="720" frameborder="0" border="0" scrolling="none"></iframe>`},
    { id: 49, title: "Lab Havoc",              thumbnail: "https://ozgames.io/cache/data/image/game/lab-havoc-m240x144.jpg", embed: `<iframe src="https://ozgames.io/lab-havoc.embed" width="1280" height="720" frameborder="0" border="0" scrolling="none"></iframe>`},
    { id: 50, title: "Cuphead",                thumbnail: "https://ozgames.io/cache/data/image/game/Cuphead-m240x144.JPG", embed: `<iframe src="https://ozgames.io/cuphead.embed" width="1280" height="720" frameborder="0" border="0" scrolling="none"></iframe>`},
    { id: 51, title: "Snowball.io",            thumbnail: "https://play-lh.googleusercontent.com/bVYC5zsBjJf-ztbarWeOp4-qTlL4h0I3ajJoCYq8xXcG1ovafqZ2steRipRK45dJTA=w526-h296-rw", embed: `<iframe src="https://ozgames.io/snowballio.embed" width="1280" height="720" frameborder="0" border="0" scrolling="none"></iframe>`},
    { id: 52, title: "Clicker Heroes",         thumbnail: "https://cdn.playsaurus.com/build/assets/clicker-heroes-screenshot-KGuEurrO.png", embed: `<iframe style="width:100%; height:100%; border: 0;" scrolling="no" allow="autoplay *; payment *; fullscreen *; microphone *; focus-without-user-activation *; screen-wake-lock *; gamepad *; clipboard-read *; clipboard-write *;" src="https://cdn.clickerheroes.com/gamebuild/index.php"></iframe>`},
    { id: 53, title: "Mr.Mine",                thumbnail: "https://cdn.playsaurus.com/build/assets/mr-mine-screenshot-C7428jSK.png", embed: `<iframe src="https://mrmine.com/game/" title="Mr.Mine" scrolling="no" allow="autoplay; payment; fullscreen; microphone; clipboard-read; focus-without-user-activation *; screen-wake-lock; gamepad; clipboard-write 'self' https://mrmine.com" webkitallowfullscreen="true" mozallowfullscreen="true" msallowfullscreen="true" allowfullscreen="true" allowfullscreen loading="eager" style="border: 0px; background-color: rgb(255, 255, 255); width: 10px; height: 10px; min-width: 100%; min-height: 100%;"></iframe>`},
    { id: 54, title: "Poker Quest",            thumbnail: "https://cdn.playsaurus.com/build/assets/poker-quest-screenshot-BDFoidpq.png", embed: `<iframe src="https://playsaurus.com/kongPokerQuest63/" title="Poker Quest" scrolling="no" allow="autoplay; payment; fullscreen; microphone; clipboard-read; focus-without-user-activation *; screen-wake-lock; gamepad; clipboard-write 'self' https://playsaurus.com/kongPokerQuest56/" webkitallowfullscreen="true" mozallowfullscreen="true" msallowfullscreen="true" allowfullscreen="true" allowfullscreen loading="eager" style="border: 0px; background-color: rgb(255, 255, 255); width: 10px; height: 10px; min-width: 100%; min-height: 100%;"></iframe>`},
    { id: 55, title: "Grindcraft",             thumbnail: "https://cdn.playsaurus.com/build/assets/grindcraft-screenshot-DoZLcEWg.png", embed: `<iframe src="https://grindcraft.com/game.php" title="Grindcraft" scrolling="no" allow="autoplay; payment; fullscreen; microphone; clipboard-read; focus-without-user-activation *; screen-wake-lock; gamepad; clipboard-write 'self' https://grindcraft.com" webkitallowfullscreen="true" mozallowfullscreen="true" msallowfullscreen="true" allowfullscreen="true" allowfullscreen loading="eager" style="border: 0px; background-color: rgb(255, 255, 255); width: 10px; height: 10px; min-width: 100%; min-height: 100%;"></iframe>`},
    { id: 56, title: "Fray Fight",             thumbnail: "https://cdn.playsaurus.com/build/assets/fray-fight-screenshot-Bn13KvoA.png", embed: `<iframe src="https://frayfight.com/game/" title="Fray Fight" scrolling="no" allow="autoplay; payment; fullscreen; microphone; clipboard-read; focus-without-user-activation *; screen-wake-lock; gamepad; clipboard-write 'self' https://frayfight.com" webkitallowfullscreen="true" mozallowfullscreen="true" msallowfullscreen="true" allowfullscreen="true" allowfullscreen loading="eager" style="border: 0px; background-color: rgb(255, 255, 255); width: 10px; height: 10px; min-width: 100%; min-height: 100%;"></iframe>`}
];

        const params = new URLSearchParams(window.location.search);
        const gameId = parseInt(params.get('id'));
        const game = gamesData.find(g => g.id === gameId);
        const main = document.getElementById('main-content');

        if (!game) {
            main.innerHTML = `
                <div class="not-found">
                    <h2>Game Not Found</h2>
                    <p>Hmm, we couldn't find that game. It may have been removed.</p>
                    <a href="index.html">← Back to All Games</a>
                </div>
            `;
        } else {
            document.title = `${game.title} — ForsakenUnblocked`;

            // Shuffle a list of "more games" (exclude current)
            const others = gamesData.filter(g => g.id !== game.id).sort(() => Math.random() - 0.5).slice(0, 12);

            const moreCards = others.map(g => `
                <a class="mini-card" href="game.html?id=${g.id}">
                    <div class="mini-thumb">
                        ${g.thumbnail ? `<img src="${g.thumbnail.replace(/ /g,'%20')}" alt="${g.title}" loading="lazy">` : ''}
                    </div>
                    <div class="mini-info">${g.title}</div>
                </a>
            `).join('');

            main.innerHTML = `
                <div class="game-meta-bar">
                    <h1>${game.title}</h1>
                    <div class="game-controls">
                        <button class="ctrl-btn fullscreen-btn" onclick="goFullscreen()">⛶ Fullscreen</button>
                    </div>
                </div>

                <div class="game-frame-wrapper">
                    <div class="iframe-box" id="iframe-box">
                        <div class="loading-overlay" id="loading-overlay">
                            <div class="spinner"></div>
                            <div class="loading-text">Loading ${game.title}...</div>
                        </div>
                        ${game.embed}
                    </div>
                </div>

                <div class="more-games-section">
                    <h2 class="more-title"><span class="bar"></span>More Games</h2>
                    <div class="more-grid">${moreCards}</div>
                </div>
            `;

            // Hide loading overlay once iframe loads
            const iframe = document.querySelector('#iframe-box iframe');
            if (iframe) {
                iframe.addEventListener('load', () => {
                    document.getElementById('loading-overlay').classList.add('hidden');
                });
                // Fallback: hide after 4s
                setTimeout(() => {
                    const ol = document.getElementById('loading-overlay');
                    if (ol) ol.classList.add('hidden');
                }, 4000);
            }
        }

        function goFullscreen() {
            const box = document.getElementById('iframe-box');
            if (!box) return;
            if (box.requestFullscreen) box.requestFullscreen();
            else if (box.webkitRequestFullscreen) box.webkitRequestFullscreen();
        }
    </script>
</body>
</html>
