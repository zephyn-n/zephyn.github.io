<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ForsakenUnblocked — Play</title>
    <link rel="icon" type="svg" href="forsakenunblockedicon.svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0d0d14;
            --surface: #13131f;
            --surface2: #1a1a2e;
            --accent1: #ff4d6d;
            --accent2: #00c9ff;
            --accent3: #f5a623;
            --accent4: #7b2fff;
            --text: #f0f0ff;
            --text-dim: #8888aa;
            --radius: 14px;
            --speed: 0.28s;
            --header-h: 68px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Nunito', sans-serif;
            background: var(--bg);
            color: var(--text);
            overflow-x: hidden;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background-image:
                radial-gradient(ellipse 80% 50% at 20% -10%, rgba(123,47,255,0.15) 0%, transparent 60%),
                radial-gradient(ellipse 60% 40% at 80% 110%, rgba(0,201,255,0.10) 0%, transparent 55%);
        }

        /* ── HEADER ── */
        header {
            position: fixed;
            top: 0; width: 100%;
            height: var(--header-h);
            background: rgba(13,13,20,0.92);
            backdrop-filter: blur(16px);
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 36px;
            z-index: 1000;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .logo {
            font-family: 'Bebas Neue', cursive;
            font-size: 1.9rem;
            letter-spacing: 2px;
            background: linear-gradient(90deg, var(--accent1), var(--accent2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-decoration: none;
        }

        .logo span { -webkit-text-fill-color: var(--accent3); }

        .back-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.07);
            border: 1.5px solid rgba(255,255,255,0.1);
            color: var(--text);
            padding: 8px 18px;
            border-radius: 50px;
            font-family: 'Nunito', sans-serif;
            font-size: 0.9rem;
            font-weight: 800;
            cursor: pointer;
            text-decoration: none;
            transition: all var(--speed);
        }
        .back-btn:hover {
            border-color: var(--accent2);
            color: var(--accent2);
            background: rgba(0,201,255,0.08);
        }

        /* ── MAIN ── */
        main {
            flex: 1;
            margin-top: var(--header-h);
            display: flex;
            flex-direction: column;
        }

        /* Game meta bar */
        .game-meta-bar {
            background: var(--surface);
            border-bottom: 1px solid rgba(255,255,255,0.05);
            padding: 16px 36px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
        }

        .game-meta-bar h1 {
            font-family: 'Bebas Neue', cursive;
            font-size: 1.8rem;
            letter-spacing: 2px;
            background: linear-gradient(90deg, var(--text), var(--accent2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .game-controls {
            display: flex;
            gap: 10px;
        }

        .ctrl-btn {
            background: rgba(255,255,255,0.07);
            border: 1.5px solid rgba(255,255,255,0.1);
            color: var(--text);
            padding: 9px 20px;
            border-radius: 8px;
            font-family: 'Nunito', sans-serif;
            font-size: 0.88rem;
            font-weight: 800;
            cursor: pointer;
            transition: all var(--speed);
        }
        .ctrl-btn:hover {
            background: rgba(255,255,255,0.13);
            border-color: var(--accent2);
            color: var(--accent2);
        }

        .ctrl-btn.fullscreen-btn:hover {
            border-color: var(--accent3);
            color: var(--accent3);
        }

        /* ── IFRAME AREA ── */
        .game-frame-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            padding: 24px 36px 36px;
            max-width: 1400px;
            width: 100%;
            margin: 0 auto;
        }

        .iframe-box {
            width: 100%;
            flex: 1;
            min-height: 580px;
            background: #000;
            border-radius: var(--radius);
            overflow: hidden;
            border: 1.5px solid rgba(255,255,255,0.07);
            box-shadow: 0 0 60px rgba(0,0,0,0.7), 0 0 0 1px rgba(0,201,255,0.08);
            position: relative;
        }

        .iframe-box iframe {
            width: 100%;
            height: 100%;
            border: none;
            display: block;
            min-height: 580px;
        }

        /* Loading overlay */
        .loading-overlay {
            position: absolute;
            inset: 0;
            background: var(--surface2);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 16px;
            border-radius: var(--radius);
            transition: opacity 0.4s ease;
        }
        .loading-overlay.hidden {
            opacity: 0;
            pointer-events: none;
        }
        .spinner {
            width: 48px; height: 48px;
            border: 4px solid rgba(255,255,255,0.1);
            border-top-color: var(--accent1);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        .loading-text {
            font-family: 'Bebas Neue', cursive;
            letter-spacing: 2px;
            font-size: 1.2rem;
            color: var(--text-dim);
        }

        /* ── MORE GAMES STRIP ── */
        .more-games-section {
            max-width: 1400px;
            width: 100%;
            margin: 0 auto;
            padding: 0 36px 50px;
        }

        .more-title {
            font-family: 'Bebas Neue', cursive;
            font-size: 1.6rem;
            letter-spacing: 2px;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-dim);
        }
        .more-title .bar {
            width: 5px; height: 24px;
            background: linear-gradient(180deg, var(--accent3), var(--accent1));
            border-radius: 4px;
        }

        .more-grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 14px;
        }

        .mini-card {
            background: var(--surface);
            border-radius: 10px;
            overflow: hidden;
            cursor: pointer;
            border: 1px solid rgba(255,255,255,0.04);
            text-decoration: none;
            color: inherit;
            transition: transform var(--speed), box-shadow var(--speed), border-color var(--speed);
            display: block;
        }
        .mini-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 24px rgba(0,0,0,0.6);
            border-color: rgba(255,77,109,0.25);
        }
        .mini-thumb {
            width: 100%;
            padding-top: 60%;
            position: relative;
            background: var(--surface2);
            overflow: hidden;
        }
        .mini-thumb img {
            position: absolute;
            inset: 0;
            width: 100%; height: 100%;
            object-fit: cover;
            transition: transform 0.35s ease;
        }
        .mini-card:hover .mini-thumb img { transform: scale(1.08); }
        .mini-info {
            padding: 8px 10px;
            font-size: 0.78rem;
            font-weight: 700;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            color: var(--text-dim);
        }
        .mini-card:hover .mini-info { color: var(--text); }

        /* ── FOOTER ── */
        footer {
            background: var(--surface);
            text-align: center;
            padding: 16px;
            border-top: 1px solid rgba(255,255,255,0.06);
            font-size: 0.85rem;
            color: var(--text-dim);
            font-weight: 600;
        }
        footer span { color: var(--accent1); }

        /* ── NOT FOUND ── */
        .not-found {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            gap: 16px;
            padding: 40px;
        }
        .not-found h2 {
            font-family: 'Bebas Neue', cursive;
            font-size: 3rem;
            letter-spacing: 3px;
            color: var(--accent1);
        }
        .not-found p { color: var(--text-dim); font-size: 1.1rem; }
        .not-found a {
            margin-top: 8px;
            padding: 12px 28px;
            border-radius: 50px;
            background: linear-gradient(135deg, var(--accent1), var(--accent4));
            color: #fff;
            text-decoration: none;
            font-weight: 800;
            font-size: 1rem;
            transition: opacity 0.2s;
        }
        .not-found a:hover { opacity: 0.85; }

        /* ── RESPONSIVE ── */
        @media (max-width: 1100px) { .more-grid { grid-template-columns: repeat(4, 1fr); } }
        @media (max-width: 768px)  {
            .more-grid { grid-template-columns: repeat(3, 1fr); }
            header { padding: 0 20px; }
            .game-meta-bar, .game-frame-wrapper, .more-games-section { padding-left: 20px; padding-right: 20px; }
            .iframe-box, .iframe-box iframe { min-height: 420px; }
        }
        @media (max-width: 480px)  {
            .more-grid { grid-template-columns: repeat(2, 1fr); }
            .iframe-box, .iframe-box iframe { min-height: 320px; }
        }
    </style>
</head>
